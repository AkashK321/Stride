# Copy to .env.inference and fill in. Used by start_inference_server.sh / start_dev_inference.py
# Do not commit .env.inference (gitignored).

# Required: physical Lambda function name (CloudFormation → Resources → ObjectDetectionHandler → Physical ID)
OBJECT_DETECTION_LAMBDA_NAME=StrideStack-yourbranch-ObjectDetectionHandlerXXXXXXXX-xxxxxxxxxxxx

# AWS region where the Lambda lives
AWS_REGION=us-east-1

# Local inference server port (ngrok and uvicorn use this)
INFERENCE_PORT=8080

# Set to 1 to require dashboard session + INFERENCE_HTTP_SECRET on Lambda (matches INFERENCE_REQUIRE_SESSION for uvicorn)
INFERENCE_REQUIRE_SESSION=0

# Set to 1 to skip starting ngrok (use with --public-url or manual tunnel)
SKIP_TUNNEL=0

# Optional: fixed public base URL (https://....) when SKIP_TUNNEL=1 or tunnel runs outside this script
# PUBLIC_URL=

# ngrok binary name or path (default ngrok)
# NGROK_CMD=ngrok
