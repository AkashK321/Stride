# Gradle folders
# Ignore Gradle project-specific cache directory
.gradle

# Ignore Gradle build output directory
build

# Ignore the library folders installed by pip
aws_resources/schema_initializer/pg8000/
aws_resources/schema_initializer/scramp/
aws_resources/schema_initializer/asn1crypto/
aws_resources/schema_initializer/cffi/
aws_resources/schema_initializer/pycparser/
aws_resources/schema_initializer/dateutil/
aws_resources/schema_initializer/six.py
aws_resources/schema_initializer/*.env
aws_resources/schema_initializer/*.dist-info/
aws_resources/schema_initializer/__pycache__/
aws_resources/schema_initializer/cfnresponse/
aws_resources/schema_initializer/urllib3/
aws_resources/sagemaker/scripts/images_in
aws_resources/sagemaker/scripts/images_pixelated

# Ignore metadata and cache files in that folder
aws_resources/schema_initializer/*.dist-info/
aws_resources/schema_initializer/__pycache__/

# Test results (keep directory and README, ignore JSON outputs)
aws_resources/test_results/*.json
!aws_resources/test_results/README.md

aws_resources/backend/build/*
aws_resources/backend/tests/integration/.env

# Model training datasets (raw images must never be committed)
model_training/bhee_raw_dataset/*
!model_training/bhee_raw_dataset/.gitkeep
model_training/bhee_clean_dataset/*
!model_training/bhee_clean_dataset/.gitkeep
model_training/logs/*
!model_training/logs/.gitkeep
model_training/.venv/

# Model training — generated annotations & dataset (regenerated by pipeline)
model_training/annotations/raw/*
!model_training/annotations/raw/.gitkeep
model_training/annotations/yolo_labels/
model_training/annotations/*.json
model_training/dataset/images/train/*
model_training/dataset/images/val/*
model_training/dataset/images/test/*
!model_training/dataset/images/train/.gitkeep
!model_training/dataset/images/val/.gitkeep
!model_training/dataset/images/test/.gitkeep
model_training/dataset/labels/train/*
model_training/dataset/labels/val/*
model_training/dataset/labels/test/*
!model_training/dataset/labels/train/.gitkeep
!model_training/dataset/labels/val/.gitkeep
!model_training/dataset/labels/test/.gitkeep
